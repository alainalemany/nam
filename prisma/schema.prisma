generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RecordStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum EquipmentCategory {
  DRAGLINE
  TRACTOR
  FORKLIFT
  WORK_TRUCK
  CABLE_SYSTEM
  CABLE_POLE
  CABLE_HANDLING_TOOL
  SUPPORT_TOOL
  OTHER
}

enum EquipmentPowerType {
  ELECTRIC
  DIESEL
  GASOLINE
  HYBRID
  OTHER
  UNKNOWN
}

enum EquipmentInstrumentationType {
  DIGITAL_ALARM_SCREEN
  SENSOR_DISPLAY
  PHYSICAL_GAUGES
  OPERATOR_OBSERVED
  MIXED
  UNKNOWN
}

enum ShiftType {
  DAY
  NIGHT
  SWING
  OTHER
  UNKNOWN
}

enum DailyLogActivityType {
  DRAGLINE_MOVE
  CUT
  GREASING
  SCHEDULED_PM
  EQUIPMENT_ALARM
  SENSOR_OBSERVATION
  EQUIPMENT_OBSERVATION
  WORK_ORDER
  WORK_AUTHORIZATION
  LOCKOUT_TAGOUT
  HOT_WORK
  WORKING_AT_HEIGHTS
  CONTRACTOR_ESCORT
  MAINTENANCE_OBSERVATION
  FUEL_SERVICE
  DELAY
  PRODUCTION_NOTE
  SAFETY_OBSERVATION
  GENERAL_NOTE
}

enum StopCardCategory {
  HAZARD_OBSERVATION
  UNSAFE_CONDITION
  UNSAFE_ACT
  NEAR_MISS
  POSITIVE_OBSERVATION
  CORRECTIVE_ACTION
  GENERAL_SAFETY
}

enum StopCardSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum StopCardStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  ARCHIVED
}

enum DailyInspectionCondition {
  SATISFACTORY
  NEEDS_ATTENTION
  UNSAFE
  NOT_APPLICABLE
}

enum DailyInspectionStatus {
  COMPLETED
  FOLLOW_UP_NEEDED
  ARCHIVED
}

enum DefectStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum DefectSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DefectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ShiftReportStatus {
  DRAFT
  COMPLETED
  ARCHIVED
}

enum WorkAuthorizationStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

enum WorkAuthorizationWorkType {
  MAINTENANCE
  ELECTRICAL
  MECHANICAL
  PREVENTIVE_MAINTENANCE
  BREAKDOWN
  HOT_WORK
  WORKING_AT_HEIGHTS
  LOCKOUT_TAGOUT
  OTHER
}

enum WeeklyScheduleStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum DailyAssignmentStatus {
  SCHEDULED
  NON_WORKING
  UNKNOWN
  CANCELLED
}

enum AssignmentCrewPhase {
  PLANNED
  ACTUAL
}

enum AssignmentCrewRole {
  PRIMARY_EMPLOYEE
  PARTNER
}

enum TimesheetStatus {
  DRAFT
  COMPLETED
}

enum EquipmentFuelType {
  DIESEL
  OFF_ROAD_DIESEL
  GASOLINE
}

enum OperationalSafetyChecklistTemplate {
  DRAGLINE_INSPECTION
  MOBILE_INSPECTION
}

enum OperationalSafetyChecklistMeterKind {
  HOURS
  MILES
}

enum OperationalSafetyChecklistItemSection {
  METADATA
  INSPECTION
}

enum OperationalSafetyChecklistResponseSet {
  CONDITION_FOUR
  CONDITION_THREE
  YES_NO
  PRESENCE_THREE
}

enum OperationalSafetyChecklistResponseCode {
  OK
  NEEDS_REPAIR
  PREVIOUSLY_NOTED
  NOT_APPLICABLE
  YES
  NO
  PRESENT
  NOT_PRESENT
}

model City {
  id        String       @id @default(cuid())
  name      String
  state     String?
  status    RecordStatus @default(ACTIVE)
  notes     String?
  mines     Mine[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([name, state])
  @@index([status])
}

model Mine {
  id                 String              @id @default(cuid())
  cityId             String
  city               City                @relation(fields: [cityId], references: [id], onDelete: Restrict)
  name               String
  type               String?
  status             RecordStatus        @default(ACTIVE)
  notes              String?
  equipment          Equipment[]
  dailyLogs          DailyLog[]
  stopCards          StopCard[]
  dailyInspections   DailyInspection[]
  shiftReports       ShiftReport[]
  workAuthorizations WorkAuthorization[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([cityId, name])
  @@index([status])
}

model Equipment {
  id                      String                        @id @default(cuid())
  mineId                  String
  mine                    Mine                          @relation(fields: [mineId], references: [id], onDelete: Restrict)
  parentEquipmentId       String?
  parentEquipment         Equipment?                    @relation("EquipmentHierarchy", fields: [parentEquipmentId], references: [id], onDelete: SetNull)
  childEquipment          Equipment[]                   @relation("EquipmentHierarchy")
  primaryDailyLogs        DailyLog[]                    @relation("DailyLogPrimaryEquipment")
  dailyLogActivities      DailyLogActivity[]            @relation("DailyLogActivityEquipment")
  stopCards               StopCard[]                    @relation("StopCardEquipment")
  dailyInspections        DailyInspection[]             @relation("DailyInspectionEquipment")
  defects                 Defect[]                      @relation("DefectEquipment")
  shiftReports            ShiftReport[]                 @relation("ShiftReportEquipment")
  workAuthorizations      WorkAuthorization[]           @relation("WorkAuthorizationEquipment")
  plannedDailyAssignments DailyAssignment[]             @relation("DailyAssignmentPlannedEquipment")
  actualDailyAssignments  DailyAssignment[]             @relation("DailyAssignmentActualEquipment")
  timesheetDailyEntries   DailyTimeEntry[]              @relation("DailyTimeEntryPrimaryEquipment")
  timesheetWorkCodes      TimesheetWorkCode[]           @relation("TimesheetWorkCodeEquipment")
  timesheetWorkOrders     TimesheetWorkOrder[]          @relation("TimesheetWorkOrderEquipment")
  safetyChecklists        OperationalSafetyChecklist[]  @relation("OperationalSafetyChecklistEquipment")
  fuelEvents              EquipmentFuelEvent[]          @relation("EquipmentFuelEventEquipment")
  equipmentNumber         String?
  displayName             String
  category                EquipmentCategory
  make                    String?
  model                   String?
  powerType               EquipmentPowerType?
  instrumentationType     EquipmentInstrumentationType?
  hasDigitalAlarmScreen   Boolean                       @default(false)
  status                  RecordStatus                  @default(ACTIVE)
  notes                   String?
  createdAt               DateTime                      @default(now())
  updatedAt               DateTime                      @updatedAt

  @@unique([mineId, displayName])
  @@index([mineId])
  @@index([category])
  @@index([status])
}

model DailyInspection {
  id                String                   @id @default(cuid())
  inspectionDate    DateTime                 @db.Date
  shift             ShiftType                @default(UNKNOWN)
  mineId            String?
  mine              Mine?                    @relation(fields: [mineId], references: [id], onDelete: SetNull)
  equipmentId       String?
  equipment         Equipment?               @relation("DailyInspectionEquipment", fields: [equipmentId], references: [id], onDelete: SetNull)
  equipmentHours    Float?
  condition         DailyInspectionCondition
  status            DailyInspectionStatus    @default(COMPLETED)
  findings          String
  defectsIdentified Boolean                  @default(false)
  notes             String?
  sourcedDefects    Defect[]                 @relation("DefectSourceDailyInspection")
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([inspectionDate])
  @@index([shift])
  @@index([mineId])
  @@index([equipmentId])
  @@index([condition])
  @@index([status])
  @@index([defectsIdentified])
}

model OperationalSafetyChecklist {
  id                    String                               @id @default(cuid())
  inspectionDate        DateTime                             @db.Date
  shift                 ShiftType
  equipmentId           String?
  equipment             Equipment?                           @relation("OperationalSafetyChecklistEquipment", fields: [equipmentId], references: [id], onDelete: SetNull, map: "SafetyChecklist_equipment_fkey")
  equipmentDisplayName  String
  equipmentNumber       String?
  equipmentCategory     EquipmentCategory
  mineName              String
  cityName              String
  cityState             String?
  templateKey           OperationalSafetyChecklistTemplate
  templateVersion       Int
  templateName          String
  meterKind             OperationalSafetyChecklistMeterKind
  startingMeter         Int
  operatorDisplayName   String
  supervisorDisplayName String
  problemDescription    String?
  responses             OperationalSafetyChecklistResponse[]
  recordVersion         Int                                  @default(1)
  createdAt             DateTime                             @default(now())
  updatedAt             DateTime                             @updatedAt

  @@unique([equipmentId, inspectionDate, shift], map: "SafetyChecklist_equipment_date_shift_key")
  @@index([inspectionDate], map: "SafetyChecklist_date_idx")
  @@index([shift], map: "SafetyChecklist_shift_idx")
  @@index([equipmentId], map: "SafetyChecklist_equipment_idx")
  @@index([templateKey], map: "SafetyChecklist_template_idx")
}

model OperationalSafetyChecklistResponse {
  id                           String                                 @id @default(cuid())
  operationalSafetyChecklistId String
  checklist                    OperationalSafetyChecklist             @relation(fields: [operationalSafetyChecklistId], references: [id], onDelete: Cascade, map: "SafetyChecklistResponse_parent_fkey")
  itemKey                      String
  itemLabel                    String
  itemOrder                    Int
  itemSection                  OperationalSafetyChecklistItemSection
  requiredMarker               String?
  responseSet                  OperationalSafetyChecklistResponseSet
  responseCode                 OperationalSafetyChecklistResponseCode
  responseLabel                String
  createdAt                    DateTime                               @default(now())
  updatedAt                    DateTime                               @updatedAt

  @@unique([operationalSafetyChecklistId, itemKey], map: "SafetyChecklistResponse_parent_item_key")
  @@unique([operationalSafetyChecklistId, itemOrder], map: "SafetyChecklistResponse_parent_order_key")
  @@index([responseCode], map: "SafetyChecklistResponse_code_idx")
  @@index([itemKey], map: "SafetyChecklistResponse_item_idx")
}

model Defect {
  id                      String           @id @default(cuid())
  reportedDate            DateTime         @db.Date
  equipmentId             String
  equipment               Equipment        @relation("DefectEquipment", fields: [equipmentId], references: [id], onDelete: Restrict)
  sourceDailyInspectionId String?
  sourceDailyInspection   DailyInspection? @relation("DefectSourceDailyInspection", fields: [sourceDailyInspectionId], references: [id], onDelete: SetNull)
  severity                DefectSeverity
  priority                DefectPriority
  status                  DefectStatus     @default(OPEN)
  title                   String
  description             String
  correctiveAction        String?
  resolutionSummary       String?
  resolvedAt              DateTime?
  closedAt                DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@index([reportedDate])
  @@index([equipmentId])
  @@index([sourceDailyInspectionId])
  @@index([status])
  @@index([severity])
  @@index([priority])
}

model StopCard {
  id               String           @id @default(cuid())
  observationDate  DateTime         @db.Date
  category         StopCardCategory
  severity         StopCardSeverity @default(MEDIUM)
  status           StopCardStatus   @default(OPEN)
  mineId           String?
  mine             Mine?            @relation(fields: [mineId], references: [id], onDelete: SetNull)
  equipmentId      String?
  equipment        Equipment?       @relation("StopCardEquipment", fields: [equipmentId], references: [id], onDelete: SetNull)
  location         String?
  description      String
  correctiveAction String?
  createdBy        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([observationDate])
  @@index([category])
  @@index([severity])
  @@index([status])
  @@index([mineId])
  @@index([equipmentId])
}

model ShiftReport {
  id                 String              @id @default(cuid())
  reportDate         DateTime            @db.Date
  shift              ShiftType           @default(UNKNOWN)
  status             ShiftReportStatus   @default(DRAFT)
  mineId             String?
  mine               Mine?               @relation(fields: [mineId], references: [id], onDelete: SetNull)
  equipmentId        String?
  equipment          Equipment?          @relation("ShiftReportEquipment", fields: [equipmentId], references: [id], onDelete: SetNull)
  location           String?
  summary            String
  operationalNotes   String?
  workAuthorizations WorkAuthorization[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([reportDate])
  @@index([shift])
  @@index([status])
  @@index([mineId])
  @@index([equipmentId])
}

model WorkAuthorization {
  id                       String                    @id @default(cuid())
  shiftReportId            String
  shiftReport              ShiftReport               @relation(fields: [shiftReportId], references: [id], onDelete: Restrict)
  status                   WorkAuthorizationStatus   @default(DRAFT)
  workType                 WorkAuthorizationWorkType
  mineId                   String?
  mine                     Mine?                     @relation(fields: [mineId], references: [id], onDelete: SetNull)
  equipmentId              String?
  equipment                Equipment?                @relation("WorkAuthorizationEquipment", fields: [equipmentId], references: [id], onDelete: SetNull)
  jobLocation              String?
  workDescription          String
  startTime                String?
  endTime                  String?
  crewWorkerCount          Int?
  contactName              String?
  equipmentRequired        String?
  personInChargeName       String?
  lockoutRequired          Boolean                   @default(true)
  lockoutNotRequiredReason String?
  workplaceExamRequired    Boolean                   @default(false)
  confinedSpaceRequired    Boolean                   @default(false)
  lockoutTagoutRequired    Boolean                   @default(true)
  hotWorkRequired          Boolean                   @default(false)
  workingAtHeightsRequired Boolean                   @default(false)
  stopCardJhaRequired      Boolean                   @default(false)
  jobCompleted             Boolean                   @default(false)
  permitsClosed            Boolean                   @default(false)
  guardsReplaced           Boolean                   @default(false)
  lockoutTagoutRemoved     Boolean                   @default(false)
  toolsRemoved             Boolean                   @default(false)
  housekeepingCompleted    Boolean                   @default(false)
  supervisorNotified       Boolean                   @default(false)
  completionNotes          String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  @@index([shiftReportId])
  @@index([status])
  @@index([workType])
  @@index([mineId])
  @@index([equipmentId])
}

model DailyLog {
  id                 String             @id @default(cuid())
  logDate            DateTime           @db.Date
  shift              ShiftType          @default(UNKNOWN)
  mineId             String?
  mine               Mine?              @relation(fields: [mineId], references: [id], onDelete: SetNull)
  primaryEquipmentId String?
  primaryEquipment   Equipment?         @relation("DailyLogPrimaryEquipment", fields: [primaryEquipmentId], references: [id], onDelete: SetNull)
  summary            String?
  weatherConditions  String?
  generalNotes       String?
  activities         DailyLogActivity[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([logDate])
  @@index([shift])
  @@index([mineId])
  @@index([primaryEquipmentId])
}

model DailyLogActivity {
  id                 String               @id @default(cuid())
  dailyLogId         String
  dailyLog           DailyLog             @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  activityDate       DateTime             @db.Date
  startTime          String?
  endTime            String?
  sequence           Int
  activityType       DailyLogActivityType
  title              String
  description        String?
  equipmentId        String?
  equipment          Equipment?           @relation("DailyLogActivityEquipment", fields: [equipmentId], references: [id], onDelete: SetNull)
  equipmentFuelEvent EquipmentFuelEvent?  @relation("EquipmentFuelEventDailyLogActivity")
  location           String?
  contractorCompany  String?
  personName         String?
  notes              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([dailyLogId])
  @@index([activityDate])
  @@index([activityType])
  @@index([equipmentId])
}

model EquipmentFuelEvent {
  id                                   String                       @id @default(cuid())
  operationalWorkDate                  DateTime                     @db.Date
  eventTime                            String
  equipmentId                          String?
  equipment                            Equipment?                   @relation("EquipmentFuelEventEquipment", fields: [equipmentId], references: [id], onDelete: SetNull, map: "FuelEvent_equipment_fkey")
  equipmentDisplayName                 String
  equipmentNumber                      String?
  equipmentCategory                    EquipmentCategory
  mineName                             String
  cityName                             String
  cityState                            String?
  fuelType                             EquipmentFuelType
  totalGallons                         Int
  fuelServicePersonId                  String?
  fuelServicePerson                    FuelServicePerson?           @relation(fields: [fuelServicePersonId], references: [id], onDelete: Restrict, map: "FuelEvent_servicePerson_fkey")
  fuelServicePersonDisplayNameSnapshot String?
  dailyLogActivityId                   String?                      @unique(map: "FuelEvent_dailyLogActivity_key")
  dailyLogActivity                     DailyLogActivity?            @relation("EquipmentFuelEventDailyLogActivity", fields: [dailyLogActivityId], references: [id], onDelete: SetNull, map: "FuelEvent_dailyLogActivity_fkey")
  notes                                String?
  tankFills                            EquipmentFuelEventTankFill[]
  createdAt                            DateTime                     @default(now())
  updatedAt                            DateTime                     @updatedAt

  @@index([operationalWorkDate], map: "FuelEvent_workDate_idx")
  @@index([equipmentId], map: "FuelEvent_equipment_idx")
  @@index([fuelType], map: "FuelEvent_fuelType_idx")
  @@index([fuelServicePersonId], map: "FuelEvent_servicePerson_idx")
}

model EquipmentFuelEventTankFill {
  id                   String             @id @default(cuid())
  equipmentFuelEventId String
  equipmentFuelEvent   EquipmentFuelEvent @relation(fields: [equipmentFuelEventId], references: [id], onDelete: Cascade, map: "FuelTankFill_event_fkey")
  sequence             Int
  tankLabel            String
  normalizedTankLabel  String
  gallons              Int
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([equipmentFuelEventId, sequence], map: "FuelTankFill_event_sequence_key")
  @@unique([equipmentFuelEventId, normalizedTankLabel], map: "FuelTankFill_event_label_key")
  @@index([equipmentFuelEventId], map: "FuelTankFill_event_idx")
}

model FuelServicePerson {
  id            String               @id @default(cuid())
  displayName   String
  normalizedKey String               @unique(map: "FuelServicePerson_normalizedKey_key")
  active        Boolean              @default(true)
  fuelEvents    EquipmentFuelEvent[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([active], map: "FuelServicePerson_active_idx")
  @@index([displayName], map: "FuelServicePerson_displayName_idx")
}

model WeeklySchedule {
  id                         String               @id @default(cuid())
  weekStartDate              DateTime             @db.Date
  weekEndDate                DateTime             @db.Date
  status                     WeeklyScheduleStatus @default(DRAFT)
  primaryEmployeeDisplayName String
  primaryEmployeeKey         String
  assignedByDisplayName      String
  receivedAt                 DateTime?
  sourceNote                 String?
  scheduleNotes              String?
  assignments                DailyAssignment[]
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt

  @@unique([weekStartDate, primaryEmployeeKey])
  @@index([weekStartDate])
  @@index([weekEndDate])
  @@index([status])
}

model DailyAssignment {
  id                          String                 @id @default(cuid())
  weeklyScheduleId            String
  weeklySchedule              WeeklySchedule         @relation(fields: [weeklyScheduleId], references: [id], onDelete: Cascade)
  assignmentDate              DateTime               @db.Date
  dayOfWeek                   Int
  plannedStatus               DailyAssignmentStatus  @default(UNKNOWN)
  plannedShift                ShiftType              @default(UNKNOWN)
  plannedEquipmentId          String?
  plannedEquipment            Equipment?             @relation("DailyAssignmentPlannedEquipment", fields: [plannedEquipmentId], references: [id], onDelete: SetNull)
  plannedEquipmentDisplayName String?
  plannedEquipmentNumber      String?
  plannedEquipmentCategory    EquipmentCategory?
  plannedMineName             String?
  plannedCityName             String?
  plannedCityState            String?
  actualStatus                DailyAssignmentStatus  @default(UNKNOWN)
  actualShift                 ShiftType              @default(UNKNOWN)
  actualEquipmentId           String?
  actualEquipment             Equipment?             @relation("DailyAssignmentActualEquipment", fields: [actualEquipmentId], references: [id], onDelete: SetNull)
  actualEquipmentDisplayName  String?
  actualEquipmentNumber       String?
  actualEquipmentCategory     EquipmentCategory?
  actualMineName              String?
  actualCityName              String?
  actualCityState             String?
  changeReason                String?
  plannedNotes                String?
  actualNotes                 String?
  crewMembers                 AssignmentCrewMember[]
  timesheetEntries            DailyTimeEntry[]
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt

  @@unique([weeklyScheduleId, assignmentDate])
  @@index([assignmentDate])
  @@index([plannedEquipmentId])
  @@index([actualEquipmentId])
  @@index([plannedStatus])
  @@index([actualStatus])
}

model AssignmentCrewMember {
  id                String              @id @default(cuid())
  dailyAssignmentId String
  dailyAssignment   DailyAssignment     @relation(fields: [dailyAssignmentId], references: [id], onDelete: Cascade)
  phase             AssignmentCrewPhase
  role              AssignmentCrewRole
  displayName       String?
  isUnknown         Boolean             @default(false)
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([dailyAssignmentId, phase, role])
  @@index([phase])
  @@index([role])
}

model WeeklyTimesheet {
  id                         String           @id @default(cuid())
  payrollWeekStartDate       DateTime         @db.Date
  payrollWeekEndDate         DateTime         @db.Date
  status                     TimesheetStatus  @default(DRAFT)
  primaryEmployeeDisplayName String
  primaryEmployeeKey         String
  workedMinutesTotal         Int              @default(0)
  regularMinutesTotal        Int              @default(0)
  overtimeMinutesTotal       Int              @default(0)
  entries                    DailyTimeEntry[]
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  @@unique([payrollWeekStartDate, primaryEmployeeKey])
  @@index([payrollWeekStartDate])
  @@index([payrollWeekEndDate])
  @@index([status])
  @@index([primaryEmployeeKey])
}

model DailyTimeEntry {
  id                                  String            @id @default(cuid())
  weeklyTimesheetId                   String
  weeklyTimesheet                     WeeklyTimesheet   @relation(fields: [weeklyTimesheetId], references: [id], onDelete: Cascade)
  workDate                            DateTime          @db.Date
  clockIn                             String
  clockOut                            String
  unpaidBreakMinutes                  Int               @default(0)
  workedMinutes                       Int
  regularMinutes                      Int               @default(0)
  overtimeMinutes                     Int               @default(0)
  primaryEquipmentId                  String?
  primaryEquipment                    Equipment?        @relation("DailyTimeEntryPrimaryEquipment", fields: [primaryEquipmentId], references: [id], onDelete: SetNull)
  primaryEquipmentDisplayNameSnapshot String
  primaryEquipmentNumberSnapshot      String?
  primaryEquipmentCategorySnapshot    EquipmentCategory
  primaryMineNameSnapshot             String
  primaryCityNameSnapshot             String
  primaryCityStateSnapshot            String?
  workScheduleDailyAssignmentId       String?
  workScheduleDailyAssignment         DailyAssignment?  @relation(fields: [workScheduleDailyAssignmentId], references: [id], onDelete: SetNull)
  notes                               String?
  allocations                         WorkAllocation[]
  createdAt                           DateTime          @default(now())
  updatedAt                           DateTime          @updatedAt

  @@unique([weeklyTimesheetId, workDate])
  @@index([workDate])
  @@index([primaryEquipmentId])
  @@index([workScheduleDailyAssignmentId])
}

model WorkAllocation {
  id                           String                        @id @default(cuid())
  dailyTimeEntryId             String
  dailyTimeEntry               DailyTimeEntry                @relation(fields: [dailyTimeEntryId], references: [id], onDelete: Cascade)
  sequence                     Int
  workCodeId                   String
  workCode                     TimesheetWorkCode             @relation(fields: [workCodeId], references: [id], onDelete: Restrict)
  workCodeSnapshot             String
  workCodeDescriptionSnapshot  String
  workOrderId                  String?
  workOrder                    TimesheetWorkOrder?           @relation(fields: [workOrderId], references: [id], onDelete: Restrict)
  workOrderSnapshot            String?
  workOrderDescriptionSnapshot String?
  allocatedMinutes             Int
  notes                        String?
  supportPersonnel             WorkAllocationSupportPerson[]
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt

  @@unique([dailyTimeEntryId, sequence])
  @@index([workCodeId])
  @@index([workOrderId])
}

model TimesheetWorkCode {
  id             String           @id @default(cuid())
  code           String
  normalizedCode String           @unique
  description    String
  category       String?
  equipmentId    String?
  equipment      Equipment?       @relation("TimesheetWorkCodeEquipment", fields: [equipmentId], references: [id], onDelete: SetNull)
  active         Boolean          @default(true)
  lastUsedAt     DateTime?
  allocations    WorkAllocation[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([active])
  @@index([equipmentId])
  @@index([code])
}

model TimesheetWorkOrder {
  id                        String           @id @default(cuid())
  workOrderNumber           String
  normalizedWorkOrderNumber String           @unique
  description               String
  equipmentId               String?
  equipment                 Equipment?       @relation("TimesheetWorkOrderEquipment", fields: [equipmentId], references: [id], onDelete: SetNull)
  active                    Boolean          @default(true)
  lastUsedAt                DateTime?
  allocations               WorkAllocation[]
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  @@index([active])
  @@index([equipmentId])
  @@index([workOrderNumber])
}

model TimesheetSupportPerson {
  id                 String                        @id @default(cuid())
  displayName        String
  normalizedIdentity String                        @unique
  tradeOrRole        String
  company            String?
  active             Boolean                       @default(true)
  notes              String?
  lastUsedAt         DateTime?
  allocationLinks    WorkAllocationSupportPerson[]
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt

  @@index([active])
  @@index([displayName])
}

model WorkAllocationSupportPerson {
  id                               String                 @id @default(cuid())
  workAllocationId                 String
  workAllocation                   WorkAllocation         @relation(fields: [workAllocationId], references: [id], onDelete: Cascade)
  supportPersonId                  String
  supportPerson                    TimesheetSupportPerson @relation(fields: [supportPersonId], references: [id], onDelete: Restrict)
  supportPersonDisplayNameSnapshot String
  supportPersonTradeOrRoleSnapshot String
  supportPersonCompanySnapshot     String?
  createdAt                        DateTime               @default(now())
  updatedAt                        DateTime               @updatedAt

  @@unique([workAllocationId, supportPersonId], map: "WorkAllocationSupportPerson_allocation_person_key")
  @@index([supportPersonId])
}
